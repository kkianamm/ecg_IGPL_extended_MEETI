+def _guard(Y, classnames, source, split=None, matched_by_name=False):
+    """Reject targets that are genuinely unusable; warn about merely sparse ones.
+
+    Two failures used to be conflated here:
+
+    * **Alias mismatch** -- the label vocabulary in labels.csv does not match
+      LABEL_ALIASES, so nothing is ever set and every AUROC comes back NaN.
+      This is the bug this module was written to catch, and it stays fatal.
+    * **Sparse-but-correct labels** -- the columns matched fine, a class just
+      has no positives in this split. Weak-labeled datasets (MEETI, via
+      `prepare_meeti.py`) hit this routinely: rare superclasses such as HYP can
+      be absent from a small val/test fold, and `--limit` smoke runs make it
+      likelier still. Aborting here would block a legitimate run.
+
+    When targets come from per-class columns matched *by name*, an alias
+    mismatch is impossible by construction, so zero counts can only be sparsity.
+    """
+    tag = f"[data_fix]{'' if split is None else ' ' + split + ':'}"
     counts = Y.sum(0)
-    if Y.sum() == 0 or (counts == 0).any():
+
+    if len(Y) == 0:
+        print(f"{tag} WARNING: split is empty (0 rows) -- skipping target check.")
+        return Y
+
+    if Y.sum() == 0:
+        if matched_by_name:
+            raise ValueError(
+                f"No positive labels at all in {split or 'this split'} from {source}. "
+                f"The columns were found by name, so this is not an alias problem -- "
+                f"labels.csv genuinely carries no positives. If you built it with "
+                f"`prepare_meeti.py --label-mode none`, the class columns are all "
+                f"zero by design: that mode is for contrastive fine-tuning "
+                f"(`finetune_clip.py --caption report`), not for supervised "
+                f"training. Re-run with `--label-mode rule` to weak-label the "
+                f"reports.")
         raise ValueError(
             f"Degenerate targets from {source}: per-class positive counts = "
